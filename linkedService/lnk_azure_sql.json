{
	"name": "lnk_azure_sql",
	"properties": {
		"parameters": {
			"prm_lnk_database": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "AzureSqlDatabase",
		"typeProperties": {
			"server": "srvsqlmbalcazar.database.windows.net",
			"database": "@{linkedService().prm_lnk_database}",
			"encrypt": "mandatory",
			"trustServerCertificate": false,
			"authenticationType": "SQL",
			"userName": "sqladmin",
			"password": {
				"type": "AzureKeyVaultSecret",
				"store": {
					"referenceName": "lnk_kv",
					"type": "LinkedServiceReference"
				},
				"secretName": "secret-azuresql-adventureworks-password"
			}
		}
	},
	"type": "Microsoft.DataFactory/factories/linkedservices"
}